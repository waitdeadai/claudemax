{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)",
      "Bash(git:*)",
      "Bash(claude:*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ]
  },
  "model": "claude-opus-4-8",
  "env": {
    "CLAUDEMAX_REPO": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "true"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/cmax-session-start.sh" },
          { "type": "command", "command": "bash .claude/hooks/dp.sh time-anchor.sh", "timeout": 3 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh state-sessionstart.sh", "timeout": 5 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/dp.sh time-anchor.sh", "timeout": 3 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/cmax-stop.sh" },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-vibes.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-curfew.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-sycophancy.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-cliffhanger.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh honest-eta.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-fake-recall.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-fake-stats.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-fake-cite.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-wrap-up.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-aggregator-hallucination.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-silent-worker-success.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-cherry-pick-rollup.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-credential-leak-in-handoff.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-phantom-tool-call.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-sandbagging-disguise.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-rollback-claim-without-evidence.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-emoji-spam.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-tldr-bait.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-meta-commentary.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-prompt-restate.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-disclaimer-spam.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-ai-tells.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-roleplay-drift.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-unreachable-symbol.sh", "timeout": 10 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh state-stop.sh", "timeout": 10 }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-vibes.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh honest-eta.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-aggregator-hallucination.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-silent-worker-success.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-cherry-pick-rollup.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-credential-leak-in-handoff.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-phantom-tool-call.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-emoji-spam.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-unreachable-symbol.sh", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-vibes.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-vibes.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-approval-sneak.sh", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/cmax-post-tool-use.sh" },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-vibes.sh", "timeout": 5 }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-vibes.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-handoff-loop.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-credential-leak-in-handoff.sh", "timeout": 5 }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-vibes.sh", "timeout": 5 },
          { "type": "command", "command": "bash .claude/hooks/dp.sh no-ownership-violation.sh", "timeout": 5 }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/dp.sh state-precompact.sh", "timeout": 10 }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/dp.sh state-postcompact.sh", "timeout": 10 }
        ]
      }
    ]
  }
}
